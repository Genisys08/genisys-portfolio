import { useEffect, useState } from "react";
import { motion, AnimatePresence } from "framer-motion";

const KEY = "genisys_cookie_ok";

interface Props {
  show:             boolean;    // FIX-3: pass loaded from App
  onVisibleChange?: (v: boolean) => void;
}

export default function CookieBanner({ show, onVisibleChange }: Props) {
  const [visible, setVisible] = useState(false);

  useEffect(() => {
    if (!show) return;
    try {
      const s = !localStorage.getItem(KEY);
      setVisible(s);
      onVisibleChange?.(s);
    } catch {
      setVisible(true);
      onVisibleChange?.(true);
    }
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [show]);

  const dismiss = () => {
    try { localStorage.setItem(KEY, "1"); } catch {}
    setVisible(false);
    onVisibleChange?.(false);
  };

  return (
    <AnimatePresence>
      {visible && (
        <motion.div
          initial={{ y: 80, opacity: 0 }}
          animate={{ y: 0,  opacity: 1 }}
          exit={{   y: 80, opacity: 0 }}
          transition={{ duration: 0.45, ease: [0.7, 0, 0.3, 1] }}
          /*
           * FIX-2: left:1rem + right:1rem anchors both edges.
           * No 100vw, no translate-x. Guaranteed within viewport on all devices.
           */
          className="fixed z-[9200] max-w-xl mx-auto"
          style={{
            left:   "1rem",
            right:  "1rem",
            bottom: "max(calc(env(safe-area-inset-bottom, 0px) + 80px), 88px)",
          }}
        >
          <div className="glass-strong specular grain rounded-2xl px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center gap-3">
            <p className="text-cream/70 text-xs leading-relaxed flex-1 min-w-0">
              This site uses cookies to analyse performance and improve your experience.
              No data is sold.{" "}
              <a href="#/studio" className="text-gold/80 hover:text-gold underline underline-offset-2 whitespace-nowrap">
                Privacy policy
              </a>.
            </p>
            <button
              type="button"
              onClick={dismiss}
              className="flex-none self-end sm:self-auto px-5 py-2 rounded-full glass gold-border-glow font-mono text-[10px] tracking-[0.3em] text-gold hover:text-cream transition-colors whitespace-nowrap"
            >
              GOT IT
            </button>
          </div>
        </motion.div>
      )}
    </AnimatePresence>
  );
}
